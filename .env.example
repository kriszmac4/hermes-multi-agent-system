# Hermes Multi-Agent System v4 — Environment Variables
# Copy this to .env and fill in your tokens.
# Each profile also needs its own .env in ~/.hermes/profiles/<name>/.env

# ─── Discord Bot Tokens ────────────────────────────────────
# Each agent has its own Discord bot. Create bots at https://discord.com/developers/applications
DISCORD_GENERAL_TOKEN=your_general_bot_token_here
DISCORD_TOKEN_DEV=your_dev_bot_token_here
DISCORD_TOKEN_RESEARCH=your_research_bot_token_here
DISCORD_TOKEN_STUDY=your_study_bot_token_here

# ─── Telegram Bot Token (General profile only) ─────────────
# Create at https://t.me/BotFather
# TELEGRAM_BOT_TOKEN is set via HERMES_HOME env or systemd service

# ─── LLM Provider API Keys ──────────────────────────────────
OPENCODE_GO_ART_API_KEY=your_opencode_go_art_key_here
OPENCODE_GO_API_KEY=your_opencode_go_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# ─── Optional: Search & Browser ────────────────────────────
GOOGLE_API_KEY=your_google_key_here
GITHUB_TOKEN=your_github_token_here

# ─── Gateway ────────────────────────────────────────────────
GATEWAY_ALLOW_ALL_USERS=true